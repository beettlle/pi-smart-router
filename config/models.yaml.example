# Example fleet catalog — copy to config/models.yaml and customize.
# See specs/001-build-smart-router/data-model.md (ModelProfile) and docs/PRD.md §5.
#
# Capability scores in this file are static examples. At runtime, mapPiModelToProfile
# prefers benchmark-grounded profiles from config/benchmark-profiles.json (SP-136)
# when a model id has an ingest row; regex/pattern defaults apply otherwise.
# Regenerate the artifact with: npm run routing:ingest-benchmarks

models:
  - id: local-gemma-4-7b
    tier: zero-tier
    provider: lmstudio
    endpoint: http://localhost:1234/v1
    capabilities:
      reasoning: 0.3
      code_gen: 0.6
      tool_use: 0.1
    performance:
      latency_p50_ms: 120
      verbosity_factor: 0.9
      cache_friendly: true
    pricing:
      registry_key: local/free
      fallback_cost_per_1m: 0.0
    limits:
      max_input_tokens: 32768
      max_output_tokens: 4096

  - id: claude-3.5-haiku
    tier: economical-cloud
    provider: anthropic
    capabilities:
      reasoning: 0.7
      code_gen: 0.75
      tool_use: 0.7
    performance:
      latency_p50_ms: 280
      verbosity_factor: 0.95
      cache_friendly: true
    pricing:
      registry_key: anthropic/claude-3-5-haiku
      fallback_cost_per_1m: 0.8
    limits:
      max_input_tokens: 200000
      max_output_tokens: 8192

  - id: claude-3.5-sonnet
    tier: frontier-cloud
    provider: anthropic
    capabilities:
      reasoning: 0.95
      code_gen: 0.95
      tool_use: 0.95
    performance:
      latency_p50_ms: 450
      verbosity_factor: 1.2
      cache_friendly: true
    pricing:
      registry_key: anthropic/claude-3-5-sonnet
      fallback_cost_per_1m: 3.0
    limits:
      max_input_tokens: 200000
      max_output_tokens: 8192
