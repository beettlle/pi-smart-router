{
  "configVersion": 1,
  "project": {
    "name": "pi-smart-router",
    "description": ""
  },
  "paths": {
    "tasksRoot": "spine-tasks"
  },
  "baseBranch": "main",
  "testing": {
    "build": "npm run typecheck && npm run lint",
    "test": "npm test",
    "testWithCoverage": "npm run coverage:check"
  },
  "agents": {
    "worker": {
      "model": "zai/glm-5.2",
      "thinking": "high"
    },
    "reviewer": {
      "model": "google/gemini-3.1-pro-preview",
      "thinking": "high",
      "plan": {
        "model": "google/gemini-flash-latest",
        "thinking": "low"
      },
      "code": {
        "model": "kimi-coding/kimi-k2-thinking",
        "thinking": "high"
      },
      "final": {
        "model": "google/gemini-3.1-pro-preview",
        "thinking": "high"
      }
    },
    "supervisor": {
      "enabled": false,
      "model": "google/gemini-flash-lite-latest",
      "pollIntervalMs": 30000,
      "autoNudge": false,
      "thinking": "off"
    },
    "activeProfile": "default",
    "profiles": {
      "default": {
        "worker": {
          "model": "zai/glm-5.2",
          "thinking": "high"
        },
        "reviewer": {
          "model": "google/gemini-3.1-pro-preview",
          "thinking": "high",
          "plan": {
            "model": "google/gemini-flash-latest",
            "thinking": "low"
          },
          "code": {
            "model": "kimi-coding/kimi-k2-thinking",
            "thinking": "high"
          },
          "final": {
            "model": "google/gemini-3.1-pro-preview",
            "thinking": "high"
          }
        },
        "supervisor": {
          "model": "google/gemini-flash-lite-latest",
          "thinking": "off"
        }
      },
      "mid": {
        "worker": {
          "model": "kimi-coding/kimi-for-coding",
          "thinking": "high"
        }
      },
      "hard": {
        "worker": {
          "model": "kimi-coding/k3",
          "thinking": "high"
        },
        "reviewer": {
          "plan": {
            "model": "kimi-coding/kimi-k2-thinking",
            "thinking": "medium"
          },
          "code": {
            "model": "google/gemini-3.1-pro-preview",
            "thinking": "high"
          },
          "final": {
            "model": "google/gemini-3.1-pro-preview",
            "thinking": "high"
          }
        }
      }
    },
    "escalatePolicy": {
      "enabled": true,
      "toProfile": "hard"
    }
  },
  "lanes": {
    "maxParallel": 3,
    "queueExcess": true,
    "workerBackend": "subprocess",
    "workerOutputMaxBytes": 262144,
    "workerOutputTailLines": 200,
    "retainWorkerOutputOnSuccess": false,
    "streamWorkerOutputLive": false,
    "workerLiveLogMaxBytes": 262144,
    "stallTimeoutMinutes": 120,
    "stallGraceAfterProgressMinutes": 30,
    "heartbeatIntervalMinutes": 10,
    "progressSnapshotIntervalMinutes": 2,
    "checkpointWarningMinutes": 10,
    "extendGraceOnFileScope": false,
    "autoCommitOnStall": false,
    "cleanupWorktreesOnComplete": true
  },
  "dashboard": {
    "port": 8129
  },
  "orchestrator": {
    "attachedMilestonePollMs": 2000,
    "sequencePollMs": 5000,
    "dashboardPollMs": 2000
  },
  "gates": {
    "requireBeforeIntegrate": true,
    "collectBuildEvidence": true,
    "collectTestEvidence": true
  },
  "integrate": {
    "isolatedWorktree": true,
    "allowHumanOnBaseBranch": "warn"
  },
  "review": {
    "requireFinalVerdict": true,
    "maxFinalAttempts": 3
  },
  "handoff": {
    "path": ".spine/handoff.md",
    "autoWriteOn": [
      "session_start"
    ]
  },
  "metrics": {
    "enabled": true,
    "path": ".spine/run-metrics.jsonl"
  },
  "contract": {
    "mode": "required",
    "legacyTaskIdPrefixes": [
      "TP-"
    ]
  },
  "worktreeSetupHook": "",
  "worktreeSetupIgnorePaths": [],
  "referenceDocs": [
    "docs/constitution.md",
    "docs/routing-roadmap.md"
  ],
  "standards": [],
  "neverLoad": []
}
